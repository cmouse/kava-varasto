# Copy to .env and fill in real values for your environment.
# Only read by settings/base.py if that file exists -- safe to omit in dev.

DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set when this deployment is mounted under a sub-path, e.g. /varasto
# (no trailing slash). Leave unset to serve from the domain root.
DJANGO_FORCE_SCRIPT_NAME=

# Comma-separated list of scheme://host origins trusted for CSRF, required
# when serving over a reverse proxy, e.g. https://webhost
DJANGO_CSRF_TRUSTED_ORIGINS=
